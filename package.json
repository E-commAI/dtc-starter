{
  "name": "medusa",
  "private": false,
  "packageManager": "npm@11.9.0",
  "scripts": {
    "setup": "PATH=$(pwd)/bin:$PATH deno install --node-modules-dir=auto --allow-scripts",
    "dev": "PATH=$(pwd)/bin:$PATH deno run -A npm:turbo dev",
    "build": "PATH=$(pwd)/bin:$PATH deno run -A npm:turbo build",
    "start": "PATH=$(pwd)/bin:$PATH deno run -A npm:turbo start",
    "lint": "PATH=$(pwd)/bin:$PATH deno run -A npm:turbo lint",
    "test": "PATH=$(pwd)/bin:$PATH deno run -A npm:turbo test",
    "backend:seed": "PATH=$(pwd)/bin:$PATH deno run -A npm:turbo seed --filter=@dtc/backend",
    "backend:dev": "PATH=$(pwd)/bin:$PATH deno run -A npm:turbo dev --filter=@dtc/backend"  
  },
  "pnpm": {
    "overrides": {
      "@types/react": "19.0.5",
      "@types/react-dom": "19.0.5"
    }
  },
  "devDependencies": {
    "turbo": "^2.0.14",
    "prettier": "^3.2.5"
  },
  "workspaces": [
    "apps/**",
    "!apps/backend/.medusa/**"
  ],
  "overrides": {
    "ajv": "^8.0.0"
  }
}